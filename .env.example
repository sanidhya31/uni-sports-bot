# ── Multi-user uniSPORT booking bot (app.app) ────────────────────────────────

# Two Telegram bots from BotFather:
TELEGRAM_BOT_TOKEN=your_public_user_bot_token     # users talk to this one
ADMIN_BOT_TOKEN=your_private_admin_bot_token       # you approve/manage here

# Your numeric Telegram user id (the admin). Falls back to TELEGRAM_ALLOWED_USER_ID.
ADMIN_USER_ID=your_numeric_telegram_user_id

# Fernet key to encrypt stored uni passwords at rest.
# Generate once:  python -m app.db genkey
USER_DB_KEY=

# Where the SQLite user store lives (default: ./users.db).
USER_DB_PATH=users.db

# Portal + polling knobs.
PORTAL_BASE_URL=https://ahs.uni-trier.de
MAX_CONCURRENT_USERS=5
POLL_INTERVAL_SECONDS=5
POLL_JITTER_SECONDS=2

# ── Legacy single-user bot (app.main, optional) ──────────────────────────────
# Only needed if you still run the old Playwright bot. The new app ignores these.
LOGIN_URL=https://ahs.uni-trier.de/login_neu.php
TARGET_URL=https://ahs.uni-trier.de/index_account.php
USERNAME=
PASSWORD=
SPORT=Badminton
DAY=Donnerstag
TIME_SLOT=14:00
